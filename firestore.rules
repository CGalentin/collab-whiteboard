rules_version = '2';

// Deploy: Firebase Console → Firestore → Rules → paste, or: firebase deploy --only firestore:rules
// MVP: any signed-in user can read/write under boards/* (tighten boardId or roles later).

service cloud.firestore {
  match /databases/{database}/documents {
    // Board root doc + every subcollection/doc under it (presence, cursors, objects, …).
    match /boards/{boardId} {
      allow read, write: if request.auth != null;

      match /{document=**} {
        allow read, write: if request.auth != null;
      }
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
