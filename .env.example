# -----------------------------------------------------------------------------
# Firebase (client) — Firebase Console → Project settings → Your apps → Web app
# -----------------------------------------------------------------------------
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Optional: shared demo board id (must match Firestore paths; default "demo" in code if unset)
# NEXT_PUBLIC_APP_DEMO_BOARD_ID=demo

# -----------------------------------------------------------------------------
# Gemini — server only (set in Vercel env; never prefix with NEXT_PUBLIC_)
# -----------------------------------------------------------------------------
GEMINI_API_KEY=
